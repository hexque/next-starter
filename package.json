{
	"name": "next-starter",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "pnpm exec ultracite fix",
		"tsc": "tsc --noEmit --watch",
		"prepare": "husky",
		"deps:check": "pnpm dlx npm-check-updates --format group",
		"deps:update": "pnpm dlx npm-check-updates -u && pnpm install"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,css}": [
			"pnpx ultracite format"
		]
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@t3-oss/env-nextjs": "^0.13.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"next": "16.0.5",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.67.0",
		"ultracite": "^6.3.8",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^24",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"tailwindcss": "^4",
		"typescript": "^5"
	},
	"packageManager": "pnpm@10.24.0"
}
